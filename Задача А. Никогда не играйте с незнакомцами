#include <iostream>
#include <algorithm>  // Для сортировки sort()
using namespace std;

int main() {
    int n;                // Размер колоды
    cin >> n;             // Читаем n
    
    int a[100005];        // Массив для карт (n ≤ 100000)
    
    // Читаем все карты
    for (int i = 0; i < n; i++) {
        cin >> a[i];
    }
    
    // Сортируем массив по возрастанию
    sort(a, a + n);
    
    // Проверяем: идут ли числа подряд?
    bool ok = true;       // Флаг: пока все хорошо
    
    for (int i = 1; i < n; i++) {
        // Если текущее число не равно предыдущему + 1
        if (a[i] != a[i - 1] + 1) {
            ok = false;   // Значит колода неправильная
            break;        // Можно дальше не проверять
        }
    }
    
    // Выводим ответ
    if (ok) {
        cout << "Deck looks good" << endl;
    } else {
        cout << "Scammed" << endl;
    }
    
    return 0;
}
