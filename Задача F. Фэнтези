#include <iostream>
#include <queue>
using namespace std;

char a[1005][1005];  // Массив для хранения карты
int n, m;            // Размеры карты

// Направления движения: вверх, вниз, влево, вправо
int dx[4] = {-1, 1, 0, 0};
int dy[4] = {0, 0, -1, 1};

// Функция поиска в ширину (BFS) от столицы
void bfs(int x, int y, char c) {
    queue<pair<int, int>> q;  // Очередь для BFS
    q.push({x, y});           // Добавляем стартовую клетку
    a[x][y] = c;              // Закрашиваем столицу (на случай, если она не закрашена)
    
    while (!q.empty()) {
        int cx = q.front().first;   // Текущая строка
        int cy = q.front().second;  // Текущий столбец
        q.pop();
        
        // Проверяем 4 направления
        for (int i = 0; i < 4; i++) {
            int nx = cx + dx[i];  // Новая строка
            int ny = cy + dy[i];  // Новый столбец
            
            // Проверяем, что новая клетка внутри карты
            if (nx >= 0 && nx < n && ny >= 0 && ny < m) {
                // Если клетка свободна ('.') - закрашиваем
                if (a[nx][ny] == '.') {
                    a[nx][ny] = c;       // Закрашиваем буквой столицы
                    q.push({nx, ny});    // Добавляем в очередь
                }
            }
        }
    }
}

int main() {
    cin >> n >> m;  // Читаем размеры карты
    
    // Читаем карту
    for (int i = 0; i < n; i++) {
        for (int j = 0; j < m; j++) {
            cin >> a[i][j];
        }
    }
    
    // Ищем все столицы и запускаем BFS от каждой
    for (int i = 0; i < n; i++) {
        for (int j = 0; j < m; j++) {
            // Если клетка - столица (буква или цифра)
            if (a[i][j] != '#' && a[i][j] != '.') {
                bfs(i, j, a[i][j]);  // Запускаем BFS с буквой столицы
            }
        }
    }
    
    // Выводим результат
    for (int i = 0; i < n; i++) {
        for (int j = 0; j < m; j++) {
            cout << a[i][j];
        }
        cout << endl;
    }
    
    return 0;
}
