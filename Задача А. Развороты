#include <iostream>
using namespace std;

int main() {
    int n;
    cin >> n;  // Читаем размер массива
    
    int a[1005];  // Создаем массив (чуть больше 1000, чтобы хватило)
    
    // Читаем элементы массива (индексация с 1, чтобы удобнее было с l и r)
    for (int i = 1; i <= n; i++) {
        cin >> a[i];
    }
    
    int l, r;  // Переменные для запроса (левая и правая граница)
    
    // Бесконечный цикл, будем выходить через break
    while (true) {
        cin >> l >> r;  // Читаем очередной запрос
        
        // Если прочитали "0 0" - завершаем программу
        if (l == 0 && r == 0) {
            break;
        }
        
        // Разворачиваем подмассив с l по r
        // Идем с двух концов к центру и меняем элементы местами
        while (l < r) {
            // Меняем местами a[l] и a[r]
            int tmp = a[l];   // Временная переменная для хранения a[l]
            a[l] = a[r];      // В a[l] кладем a[r]
            a[r] = tmp;       // В a[r] кладем старое a[l]
            
            l++;              // Сдвигаем левую границу вправо
            r--;              // Сдвигаем правую границу влево
        }
    }
    
    // Выводим получившийся массив
    for (int i = 1; i <= n; i++) {
        cout << a[i] << " ";  // Выводим каждый элемент через пробел
    }
    
    return 0;
}
