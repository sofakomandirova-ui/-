#include <iostream>
using namespace std;

int main() {
    int n;
    cin >> n;
    
    long long a[200005];
    for (int i = 1; i <= n; i++) {
        cin >> a[i];
    }
    
    long long best = -1e18;  // Лучшая найденная прибыль
    long long cur = 0;       // Текущая сумма подотрезка
    int l = 1, r = 1;        // Границы текущего подотрезка
    int bl = -1, br = -1;    // Границы лучшего подотрезка
    
    for (int i = 1; i <= n; i++) {
        // Если текущая сумма отрицательная, начинаем новый подотрезок
        if (cur < 0) {
            cur = a[i];
            l = i;
            r = i;
        } else {
            cur += a[i];
            r = i;
        }
        
        // Если нашли лучшую прибыль
        if (cur > best) {
            best = cur;
            bl = l;
            br = r;
        }
    }
    
    // Если прибыли нет (≤ 0)
    if (best <= 0) {
        cout << "-1 -1" << endl;
    } else {
        // Продажа = конец отрезка + 1
        cout << bl << " " << br + 1 << endl;
    }
    
    return 0;
}
