#include <iostream>
using namespace std;

int main() {
    int n;
    cin >> n;  // Читаем длину массива
    
    // Выводим числа от n до 1 (убывающая последовательность)
    // В такой последовательности нет возрастающих подпоследовательностей длиннее 1
    for (int i = n; i >= 1; i--) {
        cout << i << " ";
    }
    cout << endl;
    
    return 0;
}
